# Copy this file to .env and fill in your values

# MongoDB Connection
MONGODB_URI=your_mongodb_connection_string_here
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d
PORT=5000

# Google/YouTube OAuth
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:5000/api/social/youtube/callback
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:5000/api/google-calendar/callback
FRONTEND_URL=http://localhost:3000

# Groq AI Chatbot
GROQ_API_KEY=your_groq_api_key_here

# Zoho Books - Invoice Generation
ZOHO_BOOKS_CLIENT_ID=your_zoho_client_id
ZOHO_BOOKS_CLIENT_SECRET=your_zoho_client_secret
ZOHO_BOOKS_REFRESH_TOKEN=your_zoho_refresh_token
ZOHO_BOOKS_ORG_ID=your_zoho_org_id
